{
  "name": "resend-cli",
  "version": "1.2.2",
  "description": "The official CLI for Resend",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/resend/resend-cli"
  },
  "homepage": "https://github.com/resend/resend-cli#readme",
  "keywords": [
    "cli",
    "resend",
    "email",
    "api"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/cli.cjs"
  ],
  "type": "module",
  "bin": {
    "resend": "./dist/cli.cjs"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "dev:watch": "tsx --watch src/cli.ts",
    "build": "esbuild src/cli.ts --bundle --platform=node --format=cjs --minify --outfile=dist/cli.cjs",
    "build:bin": "npm run build && pkg dist/cli.cjs --compress Brotli --target node24 --output dist/resend",
    "lint": "biome check",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.config.e2e.ts"
  },
  "dependencies": {
    "@clack/prompts": "1.1.0",
    "@commander-js/extra-typings": "14.0.0",
    "commander": "14.0.3",
    "picocolors": "^1.1.1",
    "resend": "6.9.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/node": "22.15.3",
    "esbuild": "0.25.3",
    "tsx": "4.19.4",
    "typescript": "5.9.3",
    "vitest": "3.1.4",
    "@yao-pkg/pkg": "6.14.1"
  }
}
